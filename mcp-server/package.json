{
  "name": "prisma-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing the PrismaUI_F4 API reference, guides, and plugin scaffolding, fetched live from this repo on GitHub.",
  "type": "module",
  "bin": {
    "prisma-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "pack": "npx --yes @anthropic-ai/mcpb pack . prisma-mcp.mcpb"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "prismaui",
    "fallout4",
    "f4se"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PRISMA-USER-INTERFACE-FRAMEWORK/Prisma2.0.git",
    "directory": "mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
